{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*\\.html)", "destination": "/$1" },
    { "source": "/(.*\\.(css|js|webp|png|jpg|svg|ico|ttf))", "destination": "/$1" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/404.html" }
  ]
}
